.bg-background
  .relative.isolate.px-6.pt-14.lg:px-8.mx-auto
    .mx-auto.max-w-2xl.py-16.sm:py-24.lg:py-28
      %h1.text-3xl.font-bold.text-center.mb-4 Settings
      %p.text-center.text-gray-600.mb-6 Changes are saved automatically.

      - autosave_data = { controller: "autosave", autosave_delay_value: 400, action: "input->autosave#queueSubmit change->autosave#queueSubmit turbo:submit-end->autosave#handleSubmitEnd", autosave_target: "form" }

      = form_with model: @user_setting, url: user_setting_path, method: :post, data: autosave_data do |f|
        = render "form_field", f: f

      .rounded-xl.border.border-gray-200.bg-white.p-6.shadow-sm.mt-8
        %h2.text-lg.font-semibold.text-gray-900.mb-4 Credit Card Types
        %p.text-sm.text-gray-600.mb-4 Add a bank name and the last 4 digits of the card.

        - if @credit_card_type&.errors&.any?
          .rounded-md.bg-red-50.px-3.py-2.text-sm.font-semibold.text-red-700.mb-4
            = @credit_card_type.errors.full_messages.to_sentence

        - details_open = @credit_card_type&.errors&.any?
        %details{ open: details_open, class: "rounded-lg border border-dashed border-gray-200 p-4" }
          %summary.inline-flex.items-center.rounded-md.bg-gray-900.px-3.py-2.text-sm.font-semibold.text-white.shadow-sm.hover:bg-gray-800.cursor-pointer
            Add Credit Card Type
          .mt-4
            = form_with model: @credit_card_type, url: user_setting_credit_card_types_path, method: :post do |f|
              .grid.grid-cols-1.gap-4.sm:grid-cols-2
                .field
                  = f.label :bank_name, "Bank Name", class: "block text-gray-700 font-bold mb-2"
                  = f.text_field :bank_name, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                .field
                  = f.label :last4, "Last 4 Digits", class: "block text-gray-700 font-bold mb-2"
                  = f.text_field :last4, maxlength: 4, inputmode: "numeric", pattern: "[0-9]*", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
              .mt-4
                = f.submit "Add Card", class: "inline-flex items-center rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800"

        - if @credit_card_types.present?
          %ul.divide-y.divide-gray-200.mt-6
            - @credit_card_types.each do |card_type|
              %li.py-3.flex.items-center.justify-between
                %div
                  %p.text-sm.font-medium.text-gray-900= card_type.bank_name
                  %p.text-xs.text-gray-500= "**** #{card_type.last4}"
        - else
          %p.text-sm.text-gray-500.mt-6 No credit card types added yet.

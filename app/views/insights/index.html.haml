%body.bg-background
  .bg-background
    .relative.isolate.mx-auto.px-6.pb-16.pt-8.lg:px-8
      .mx-auto.max-w-6xl.py-12.sm:py-16
        - currency = current_user.user_setting.default_currency
        - total_card_label = Money.new(@card_spend * 100, currency).format(symbol: true, with_currency: false)
        - total_cash_label = Money.new(@cash_spend * 100, currency).format(symbol: true, with_currency: false)
        - total_cash_in_label = Money.new(@total_cash_in * 100, currency).format(symbol: true, with_currency: false)
        - total_spend_label = Money.new(@total_spend * 100, currency).format(symbol: true, with_currency: false)
        - net_total_label = Money.new(@net_total * 100, currency).format(symbol: true, with_currency: false)

        .mb-8.flex.flex-col.gap-4.lg:flex-row.lg:items-end.lg:justify-between
          .space-y-3
            %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.uppercase.tracking-widest.text-emerald-700 Spending Insights
            .space-y-2
              %h1.text-4xl.font-black.tracking-tight.text-slate-900 Insights
              %p.max-w-2xl.text-sm.leading-6.text-slate-600 Review six months of spending and cash-in activity to spot where your money is moving.
          = link_to expenses_path, class: "inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" do
            View Expenses

        .mb-6.grid.grid-cols-1.gap-4.lg:grid-cols-4
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Total Spend
            %p.mt-3.text-3xl.font-black.text-slate-900= total_spend_label
            %p.mt-2.text-sm.text-slate-500 Cash, card, and other outgoing payments
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Total Cash-ins
            %p.mt-3.text-3xl.font-black.text-slate-900= total_cash_in_label
            %p.mt-2.text-sm.text-slate-500 Money flowing back in
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Net Position
            - net_classes = @net_total.negative? ? "text-rose-600" : "text-emerald-600"
            %p.mt-3.text-3xl.font-black{ class: net_classes }= net_total_label
            %p.mt-2.text-sm.text-slate-500 Cash-in minus total spend
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Period
            %p.mt-3.text-2xl.font-black.text-slate-900 6 months
            %p.mt-2.text-sm.text-slate-500 Rolling month-by-month view

        .mb-10.grid.grid-cols-1.gap-4.md:grid-cols-3
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Card Payments
            %p.mt-3.text-2xl.font-bold.text-slate-900= total_card_label
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Cash Payments
            %p.mt-3.text-2xl.font-bold.text-slate-900= total_cash_label
          .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
            %p.text-sm.font-semibold.text-slate-500 Other Payments
            %p.mt-3.text-2xl.font-bold.text-slate-900
              = Money.new(@other_spend * 100, currency).format(symbol: true, with_currency: false)

        .rounded-3xl.border.border-slate-200.bg-white.p-6.shadow-xl
          .mb-5.flex.flex-col.gap-4.lg:flex-row.lg:items-start.lg:justify-between
            %div.space-y-2
              %h2.text-xl.font-bold.text-slate-900 Monthly cashflow comparison
              %p.text-sm.leading-6.text-slate-500 Cash, card, other payments, and cash-ins over the last 6 months.
            .flex.flex-wrap.items-center.gap-4.text-sm.text-slate-600
              .flex.items-center.gap-2
                %span.inline-block.h-3.w-3.rounded-full.bg-emerald-500
                Cash Payments
              .flex.items-center.gap-2
                %span.inline-block.h-3.w-3.rounded-full.bg-indigo-500
                Card Payments
              .flex.items-center.gap-2
                %span.inline-block.h-3.w-3.rounded-full.bg-slate-400
                Other Payments
              .flex.items-center.gap-2
                %span.inline-block.h-3.w-3.rounded-full.bg-sky-500
                Cash-ins

          - if @max_spend.zero? && @max_cash_in.zero?
            .rounded-2xl.border.border-dashed.border-slate-300.bg-slate-50.p-6.text-sm.text-slate-600
              No cash activity in the last 6 months.
          - else
            - chart_width = 640
            - chart_height = 240
            - padding = 28
            - max_value = @max_cashflow_value.to_f
            - x_step = @monthly_rows.size > 1 ? (chart_width - (padding * 2)).fdiv(@monthly_rows.size - 1) : 0
            - y_for = ->(value) { max_value.zero? ? (chart_height - padding) : (chart_height - padding - ((value.to_f / max_value) * (chart_height - (padding * 2)))).round(2) }
            - cash_coords = @monthly_rows.map.with_index { |row, index| [(padding + (index * x_step)).round(2), y_for.call(row[:cash])] }
            - card_coords = @monthly_rows.map.with_index { |row, index| [(padding + (index * x_step)).round(2), y_for.call(row[:card])] }
            - other_coords = @monthly_rows.map.with_index { |row, index| [(padding + (index * x_step)).round(2), y_for.call(row[:other])] }
            - cash_in_coords = @monthly_rows.map.with_index { |row, index| [(padding + (index * x_step)).round(2), y_for.call(row[:cash_in])] }
            - cash_points = cash_coords.map { |point| "#{point[0]},#{point[1]}" }.join(" ")
            - card_points = card_coords.map { |point| "#{point[0]},#{point[1]}" }.join(" ")
            - other_points = other_coords.map { |point| "#{point[0]},#{point[1]}" }.join(" ")
            - cash_in_points = cash_in_coords.map { |point| "#{point[0]},#{point[1]}" }.join(" ")
            - spline_path = lambda do |points|
              - next "" if points.empty?
              - return "M #{points[0][0]},#{points[0][1]}" if points.length == 1
              - path = +"M #{points[0][0]},#{points[0][1]}"
              - points.each_with_index do |point, index|
                - next if index == 0
                - p0 = points[index - 2] || points[index - 1]
                - p1 = points[index - 1]
                - p2 = point
                - p3 = points[index + 1] || point
                - c1x = (p1[0] + (p2[0] - p0[0]) / 6.0).round(2)
                - c1y = (p1[1] + (p2[1] - p0[1]) / 6.0).round(2)
                - c2x = (p2[0] - (p3[0] - p1[0]) / 6.0).round(2)
                - c2y = (p2[1] - (p3[1] - p1[1]) / 6.0).round(2)
                - path << " C #{c1x},#{c1y} #{c2x},#{c2y} #{p2[0]},#{p2[1]}"
              - path
            - cash_in_spline = spline_path.call(cash_in_coords)
            - cash_spline = spline_path.call(cash_coords)
            - card_spline = spline_path.call(card_coords)
            - other_spline = spline_path.call(other_coords)

            .space-y-4{ data: { controller: "frequency-tabs" } }
              .inline-flex.rounded-full.border.border-slate-200.bg-white.p-1.shadow-sm{ role: "tablist" }
                %button.rounded-full.px-4.py-2.text-sm.font-semibold{ type: "button", role: "tab", aria: { selected: "true", controls: "cashflow-panel-line" }, data: { action: "click->frequency-tabs#show", frequency_tabs_target: "tab", frequency_value: "line", active: "true", active_class: "bg-slate-900 text-white", inactive_class: "bg-white text-slate-700 hover:bg-slate-50" } } Line
                %button.rounded-full.px-4.py-2.text-sm.font-semibold{ type: "button", role: "tab", aria: { selected: "false", controls: "cashflow-panel-spline" }, data: { action: "click->frequency-tabs#show", frequency_tabs_target: "tab", frequency_value: "spline", active_class: "bg-slate-900 text-white", inactive_class: "bg-white text-slate-700 hover:bg-slate-50" } } Spline

              %section.rounded-2xl.border.border-slate-200.bg-slate-50.p-4{ id: "cashflow-panel-line", role: "tabpanel", data: { frequency_tabs_target: "panel", frequency: "line" } }
                %svg{ class: "w-full h-64", viewBox: "0 0 #{chart_width} #{chart_height}", role: "img", "aria-label": "Monthly cashflow line chart" }
                  %defs
                    %linearGradient{ id: "cash-in-gradient", x1: "0", y1: "0", x2: "0", y2: "1" }
                      %stop{ offset: "0%", "stop-color": "#0ea5e9", "stop-opacity": "0.25" }
                      %stop{ offset: "100%", "stop-color": "#0ea5e9", "stop-opacity": "0.02" }
                  -# Grid lines
                  - (0..3).each do |index|
                    - y = padding + ((chart_height - (padding * 2)) * index / 3.0)
                    %line{ x1: padding, x2: chart_width - padding, y1: y, y2: y, stroke: "#e5e7eb", "stroke-width": "1" }
                  -# Cash-in area
                  %path{ d: "M #{cash_in_points} L #{chart_width - padding},#{chart_height - padding} L #{padding},#{chart_height - padding} Z", fill: "url(#cash-in-gradient)" }
                  %polyline{ points: cash_in_points, fill: "none", stroke: "#0ea5e9", "stroke-width": "2.5" }
                  %polyline{ points: cash_points, fill: "none", stroke: "#10b981", "stroke-width": "2.5" }
                  %polyline{ points: card_points, fill: "none", stroke: "#6366f1", "stroke-width": "2.5" }
                  %polyline{ points: other_points, fill: "none", stroke: "#94a3b8", "stroke-width": "2.5", "stroke-dasharray": "4 4" }

                  - @monthly_rows.each_with_index do |row, index|
                    - x = (padding + (index * x_step)).round(2)
                    - cash_y = y_for.call(row[:cash])
                    - card_y = y_for.call(row[:card])
                    - other_y = y_for.call(row[:other])
                    - cash_in_y = y_for.call(row[:cash_in])
                    %circle{ cx: x, cy: cash_in_y, r: "3", fill: "#0ea5e9" }
                    %circle{ cx: x, cy: cash_y, r: "3", fill: "#10b981" }
                    %circle{ cx: x, cy: card_y, r: "3", fill: "#6366f1" }
                    %circle{ cx: x, cy: other_y, r: "3", fill: "#94a3b8" }

                  -# X-axis labels
                  - @monthly_rows.each_with_index do |row, index|
                    - x = (padding + (index * x_step)).round(2)
                    %text{ x: x, y: chart_height - 6, "text-anchor": "middle", "font-size": "11", fill: "#6b7280" }= row[:month]

              %section.rounded-2xl.border.border-slate-200.bg-slate-50.p-4.hidden{ id: "cashflow-panel-spline", role: "tabpanel", data: { frequency_tabs_target: "panel", frequency: "spline" } }
                %svg{ class: "w-full h-64", viewBox: "0 0 #{chart_width} #{chart_height}", role: "img", "aria-label": "Monthly cashflow spline chart" }
                  %defs
                    %linearGradient{ id: "cash-in-spline-gradient", x1: "0", y1: "0", x2: "0", y2: "1" }
                      %stop{ offset: "0%", "stop-color": "#0ea5e9", "stop-opacity": "0.25" }
                      %stop{ offset: "100%", "stop-color": "#0ea5e9", "stop-opacity": "0.02" }
                  -# Grid lines
                  - (0..3).each do |index|
                    - y = padding + ((chart_height - (padding * 2)) * index / 3.0)
                    %line{ x1: padding, x2: chart_width - padding, y1: y, y2: y, stroke: "#e5e7eb", "stroke-width": "1" }
                  -# Cash-in spline area
                  %path{ d: "#{cash_in_spline} L #{chart_width - padding},#{chart_height - padding} L #{padding},#{chart_height - padding} Z", fill: "url(#cash-in-spline-gradient)" }
                  %path{ d: cash_in_spline, fill: "none", stroke: "#0ea5e9", "stroke-width": "2.5" }
                  %path{ d: cash_spline, fill: "none", stroke: "#10b981", "stroke-width": "2.5" }
                  %path{ d: card_spline, fill: "none", stroke: "#6366f1", "stroke-width": "2.5" }
                  %path{ d: other_spline, fill: "none", stroke: "#94a3b8", "stroke-width": "2.5", "stroke-dasharray": "4 4" }

                  - @monthly_rows.each_with_index do |row, index|
                    - x = (padding + (index * x_step)).round(2)
                    - cash_y = y_for.call(row[:cash])
                    - card_y = y_for.call(row[:card])
                    - other_y = y_for.call(row[:other])
                    - cash_in_y = y_for.call(row[:cash_in])
                    %circle{ cx: x, cy: cash_in_y, r: "3", fill: "#0ea5e9" }
                    %circle{ cx: x, cy: cash_y, r: "3", fill: "#10b981" }
                    %circle{ cx: x, cy: card_y, r: "3", fill: "#6366f1" }
                    %circle{ cx: x, cy: other_y, r: "3", fill: "#94a3b8" }

                  -# X-axis labels
                  - @monthly_rows.each_with_index do |row, index|
                    - x = (padding + (index * x_step)).round(2)
                    %text{ x: x, y: chart_height - 6, "text-anchor": "middle", "font-size": "11", fill: "#6b7280" }= row[:month]

            .mt-6.grid.grid-cols-1.gap-4.sm:grid-cols-2.xl:grid-cols-3
              - @monthly_rows.each do |row|
                - net = row[:cash_in] - row[:total_spend]
                .rounded-2xl.border.border-slate-200.bg-white.p-4.shadow-sm
                  %div.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500= row[:month]
                  %div.mt-3.text-sm.text-slate-700
                    = "Cash: #{Money.new(row[:cash] * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)}"
                  %div.text-sm.text-slate-700
                    = "Card: #{Money.new(row[:card] * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)}"
                  - if row[:other].positive?
                    %div.text-sm.text-slate-700
                      = "Other: #{Money.new(row[:other] * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)}"
                  %div.text-sm.text-slate-700
                    = "Cash-in: #{Money.new(row[:cash_in] * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)}"
                  - net_class = net.negative? ? "text-rose-600" : "text-emerald-600"
                  %div.mt-2.text-sm.font-semibold{ class: net_class }
                    = "Net: #{Money.new(net * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)}"

%body.bg-background
  .bg-background
    .relative.isolate.mx-auto.overflow-hidden.px-6.pb-16.pt-8.lg:px-8
      .mx-auto.max-w-6xl.py-12.sm:py-16
        .mb-8.flex.flex-col.gap-4.lg:flex-row.lg:items-end.lg:justify-between
          .space-y-3
            %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.uppercase.tracking-widest.text-emerald-700 Spending Hub
            %div.space-y-2
              %h1.text-4xl.font-black.tracking-tight.text-slate-900 Expenses
              %p.max-w-2xl.text-sm.leading-6.text-slate-600
                Track manual spending, review due-linked charges, and keep your payment history readable at a glance.
          .flex.items-center.gap-3
            = link_to lists_path, class: "inline-flex items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-400 hover:bg-white" do
              Back to Dues

        .grid.grid-cols-1.gap-8.lg:grid-cols-3
          .lg:col-span-1
            .rounded-3xl.border.border-slate-200.bg-white.p-6.shadow-xl.backdrop-blur
              .mb-6.space-y-2
                %h2.text-xl.font-bold.text-slate-900 Add Manual Expense
                %p.text-sm.leading-6.text-slate-500 Add one-off purchases and cash spending to keep your history complete.
            - card_options = @credit_card_types.map { |card| ["#{card.bank_name} (**** #{card.last4})", card.id] }
            - card_field_hidden = @expense.payment_method != "card"
            = form_with(model: @expense, url: expenses_path, class: "space-y-5", data: { controller: "payment-method" }) do |f|
              - if @expense.errors.any?
                .rounded-2xl.border.border-red-200.bg-red-50.p-4.text-sm.text-red-700
                  = @expense.errors.full_messages.to_sentence

              .space-y-2
                = f.label :name, class: "block text-sm font-semibold text-slate-700"
                = f.text_field :name, class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100", placeholder: "Groceries, subway fare, etc."

              .grid.grid-cols-1.gap-4.sm:grid-cols-2
                .space-y-2
                  = f.label :amount, class: "block text-sm font-semibold text-slate-700"
                  = f.number_field :amount, step: "0.01", class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100", placeholder: "0.00"

                .space-y-2
                  = f.label :paid_at, "Paid on", class: "block text-sm font-semibold text-slate-700"
                  = f.date_field :paid_at, class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100"

              .space-y-2
                = f.label :payment_method, class: "block text-sm font-semibold text-slate-700"
                = f.select :payment_method,
                  [["Cash In", "cash_in"], ["Cash", "cash"], ["Card", "card"], ["Bank Transfer", "bank_transfer"], ["Other", "other"]],
                  { include_blank: "Select method" },
                  class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100",
                  data: { action: "change->payment-method#update", payment_method_target: "methodSelect" }

              .space-y-2{ hidden: card_field_hidden, data: { payment_method_target: "cardField" } }
                = f.label :credit_card_type_id, "Card Type", class: "block text-sm font-semibold text-slate-700"
                = f.select :credit_card_type_id,
                  card_options,
                  { include_blank: "Select card" },
                  class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-emerald-400 focus:ring-2 focus:ring-emerald-100",
                  data: { payment_method_target: "cardSelect" }

              = f.submit "Add Expense", class: "inline-flex w-full items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-slate-800"

          .lg:col-span-2
            .rounded-3xl.border.border-slate-200.bg-white.shadow-xl.backdrop-blur
              .flex.flex-col.gap-4.border-b.border-slate-100.p-6.sm:flex-row.sm:items-end.sm:justify-between
                .space-y-2
                  %h2.text-xl.font-bold.text-slate-900 Expense List
                  - if @total_expenses.positive?
                    - start_count = ((@page - 1) * @per_page) + 1
                    - end_count = [@page * @per_page, @total_expenses].min
                    %p.text-sm.text-slate-500
                      Showing #{start_count}-#{end_count} of #{@total_expenses} expenses
                  - else
                    %p.text-sm.text-slate-500 No expenses recorded yet
                - if @total_expenses.positive?
                  = form_with url: expenses_path, method: :get, local: true, class: "flex items-center gap-2" do
                    = label_tag :per_page, "Rows per page", class: "text-sm font-semibold text-slate-600"
                    = select_tag :per_page,
                      options_for_select(@per_page_options.map { |value| [value, value] }, @per_page),
                      class: "rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900 shadow-sm",
                      onchange: "this.form.submit()"
                    = submit_tag "Apply", class: "rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"

              .overflow-x-auto
                %table.min-w-full
                  %thead
                    %tr.border-b.border-slate-100.bg-slate-50
                      %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Name
                      %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Source
                      %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Paid On
                      %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Due Date
                      %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Method
                      %th.px-5.py-4.text-right.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Amount
                      %th.px-5.py-4.text-right.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Action
                  %tbody.divide-y.divide-slate-100
                    - if @expenses.any?
                      - @expenses.each do |expense|
                        - source_label = expense.source == Expense::SOURCE_DUE ? "Due" : "Manual"
                        - source_classes = expense.source == Expense::SOURCE_DUE ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-700"
                        - paid_at_label = expense.paid_at&.strftime("%b %d, %Y") || "N/A"
                        - due_date_label = expense.due_date&.strftime("%b %d, %Y") || "—"
                        - method_label = expense.payment_method.present? ? expense.payment_method.tr("_", " ").titleize : "Unspecified"
                        %tr.transition.hover:bg-emerald-50
                          %td.px-5.py-4.text-sm.text-slate-900
                            .flex.flex-col.gap-1
                              - if expense.list.present?
                                = link_to expense.name, list_path(expense.list), class: "font-semibold text-slate-900 underline decoration-emerald-300 decoration-2 underline-offset-4"
                                %span.text-xs.text-slate-500 Linked to due list
                              - else
                                %span.font-semibold= expense.name
                                %span.text-xs.text-slate-500 Manual expense entry
                          %td.px-5.py-4.text-sm.text-slate-700
                            %span.inline-flex.items-center.rounded-full.px-3.py-1.text-xs.font-semibold{ class: source_classes }= source_label
                          %td.px-5.py-4.text-sm.text-slate-700= paid_at_label
                          %td.px-5.py-4.text-sm.text-slate-700= due_date_label
                          %td.px-5.py-4.text-sm.text-slate-700= method_label
                          %td.px-5.py-4.text-right.text-sm.font-semibold.text-slate-900
                            = Money.new(expense.amount * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)
                          %td.px-5.py-4.text-right.text-sm
                            = link_to "Edit", edit_expense_path(expense), class: "inline-flex items-center rounded-full border border-slate-300 px-3 py-1.5 font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
                    - else
                      %tr
                        %td.px-5.py-12.text-center.text-sm.text-slate-500{ colspan: "7" }
                          .mx-auto.max-w-sm.space-y-2
                            %p.text-base.font-semibold.text-slate-700 No expenses yet.
                            %p Add your first manual expense to start building a clean spending history.

              - if @total_expenses.positive?
                .flex.flex-col.gap-4.border-t.border-slate-100.p-6.text-sm.text-slate-600.sm:flex-row.sm:items-center.sm:justify-between
                  %p
                    Viewing #{@expenses.size} item#{@expenses.size == 1 ? "" : "s"} on this page
                  .flex.items-center.gap-3.self-start.sm:self-auto
                    - if @total_pages.to_i > 1
                      %span.font-semibold.text-slate-700 Page #{@page} of #{@total_pages}
                      .flex.items-center.gap-2
                        - if @page > 1
                          = link_to "Previous", expenses_path(page: @page - 1, per_page: @per_page), class: "rounded-full border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 transition hover:bg-slate-50"
                        - if @page < @total_pages
                          = link_to "Next", expenses_path(page: @page + 1, per_page: @per_page), class: "rounded-full border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 transition hover:bg-slate-50"

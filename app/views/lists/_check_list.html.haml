.check-list{ "data-controller" => "check" }
  - if @lists_with_due_dates.any?
    %ul.space-y-3
      - @lists_with_due_dates.each do |entry|
        - list = entry[:list]
        - due_date = entry[:due_date]
        - checked = list.checked_status_for(current_user, due_date).to_s
        - card_classes = checked == "true" ? "border-emerald-200 bg-emerald-50" : "border-slate-200 bg-white hover:border-emerald-200 hover:bg-emerald-50/40"
        %li.rounded-2xl.border.p-4.transition{ class: card_classes, "data-check-target" => "listItem", "data-list-id" => list.id }
          .flex.items-start.justify-between.gap-4
            .flex.min-w-0.items-start.gap-3
              %button.flex.h-10.w-10.items-center.justify-center.rounded-full.border.border-slate-200.bg-white.shadow-sm.transition.hover:border-emerald-300.hover:bg-emerald-50{ type: "button", "data-action" => "click->check#toggle", "data-check-target" => "icon", "data-checked" => checked, "aria-label" => "Toggle paid status" }
                - if checked == "true"
                  %svg{ xmlns: "http://www.w3.org/2000/svg", class: "h-5 w-5 text-emerald-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor" }
                    %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M5 13l4 4L19 7" }
                - else
                  %svg{ xmlns: "http://www.w3.org/2000/svg", class: "h-5 w-5 text-slate-500", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor" }
                    %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" }
              .min-w-0.space-y-2
                .flex.flex-wrap.items-center.gap-2
                  %span.inline-flex.items-center.rounded-full.bg-slate-100.px-3.py-1.text-xs.font-semibold.text-slate-600
                    = Money.new(list.price * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)
                  - if checked == "true"
                    %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.text-emerald-700 Paid
                  - else
                    %span.inline-flex.items-center.rounded-full.bg-amber-100.px-3.py-1.text-xs.font-semibold.text-amber-700 Due
                = link_to list_path(list), class: "block truncate text-base font-semibold text-slate-900 underline decoration-emerald-300 decoration-2 underline-offset-4" do
                  = list.name
                - if list.description.present?
                  %p.text-sm.leading-6.text-slate-500= list.description
            .shrink-0.text-right
              %p.text-xs.font-semibold.uppercase.tracking-widest.text-slate-400 Due Date
              %span.text-sm.font-semibold.text-slate-700{ "data-due-date" => due_date.to_s }
                - if due_date.present?
                  = due_date.strftime('%b %d')
                - else
                  = "No due date"
  - else
    .rounded-2xl.border.border-dashed.border-slate-300.bg-slate-50.p-10.text-center
      %p.text-base.font-semibold.text-slate-700 No dues in this range.
      %p.mt-2.text-sm.text-slate-500 Try changing the date range or add a new list to get started.

  .fixed.inset-0.z-50.hidden.items-center.justify-center.p-4{ class: "bg-black/50", "data-check-target" => "modal" }
    .w-full.max-w-sm.rounded-3xl.bg-white.p-6.shadow-2xl
      %h3.text-lg.font-semibold.text-slate-900 How was this paid?
      %p.mt-1.text-sm.text-slate-600 Choose a payment method to record the expense.
      - card_options = @credit_card_types.map { |card| ["#{card.bank_name} (**** #{card.last4})", card.id] }
      .mt-4.grid.grid-cols-2.gap-3
        %button{ type: "button", class: "rounded-2xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50", "data-action" => "click->check#choosePayment", "data-payment-method" => "card" } Card
        %button{ type: "button", class: "rounded-2xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50", "data-action" => "click->check#choosePayment", "data-payment-method" => "cash" } Cash
      .mt-4{ hidden: true, "data-check-target" => "cardField" }
        %label.block.text-sm.font-semibold.text-slate-700 Card Type
        %select.w-full.rounded-2xl.border.border-slate-300.px-3.py-3.text-slate-900{ "data-check-target" => "cardSelect" }
          %option{ value: "" } Select card
          - card_options.each do |label, value|
            %option{ value: value }= label
        %p.mt-2.text-xs.text-red-600.hidden{ "data-check-target" => "cardError" } Please choose a card type.
      .mt-5
        %button{ type: "button", class: "text-sm font-semibold text-slate-700 underline", "data-action" => "click->check#cancelPayment" } Cancel

.check-list{ "data-controller" => "check" }
  %ul
    - @lists_with_due_dates.each do |entry|
      - list = entry[:list]
      - due_date = entry[:due_date]
      - checked = list.checked_status_for(current_user, due_date).to_s # Get the checked status for the current user in strings
      %li{ class: "grid grid-cols-[minmax(0,1fr)_auto] items-center gap-3 mb-4", "data-check-target" => "listItem", "data-list-id" => list.id }
        .flex.items-center.min-w-0
          %span{ "data-action" => "click->check#toggle", "data-check-target" => "icon", "data-checked" => checked }
            - if checked
              %svg{ xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-black", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M5 13l4 4L19 7" } # Checked icon (checkmark)
            - else
              %svg{ xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-gray-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" } # Unchecked icon (plus sign)
          %label.ml-2.min-w-0{ for: "list_#{list.id}" }
            = link_to list_path(list), class: 'flex items-center gap-1 min-w-0' do
              %span.text-gray-900.font-medium.shrink-0= Money.new(list.price * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)
              %span.text-gray-700.shrink-0= " for "
              %span.font-medium.text-gray-900.truncate= list.name
        %span.text-gray-700.text-right{ "data-due-date" => due_date.to_s }
          - if due_date.present?
            = due_date.strftime('%b %d')
          - else
            = "No due date"
  .fixed.inset-0.z-50.hidden.items-center.justify-center{ class: "bg-black/50", "data-check-target" => "modal" }
    .w-full.max-w-sm.rounded-xl.bg-white.p-6.shadow-xl
      %h3.text-lg.font-semibold.text-gray-900 How was this paid?
      %p.mt-1.text-sm.text-gray-600 Choose a payment method to record the expense.
      - card_options = @credit_card_types.map { |card| ["#{card.bank_name} (**** #{card.last4})", card.id] }
      .mt-4.grid.grid-cols-2.gap-3
        %button{ type: "button", class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50", "data-action" => "click->check#choosePayment", "data-payment-method" => "card" } Card
        %button{ type: "button", class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50", "data-action" => "click->check#choosePayment", "data-payment-method" => "cash" } Cash
      .mt-4{ hidden: true, "data-check-target" => "cardField" }
        %label.block.text-sm.font-semibold.text-gray-700 Card Type
        %select.w-full.rounded-md.border.border-gray-300.px-3.py-2.text-gray-900{ "data-check-target" => "cardSelect" }
          %option{ value: "" } Select card
          - card_options.each do |label, value|
            %option{ value: value }= label
        %p.mt-2.text-xs.text-red-600.hidden{ "data-check-target" => "cardError" } Please choose a card type.
      .mt-4
        %button{ type: "button", class: "text-sm font-semibold text-gray-700 underline", "data-action" => "click->check#cancelPayment" } Cancel

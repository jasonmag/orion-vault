.bg-background
  .relative.isolate.mx-auto.px-6.pb-16.pt-8.lg:px-8
    .mx-auto.max-w-5xl.py-12.sm:py-16
      .mb-8.flex.flex-col.gap-4.lg:flex-row.lg:items-end.lg:justify-between
        %div.space-y-3
          %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.uppercase.tracking-widest.text-emerald-700 Recurring Dues
          %div.space-y-2
            %h1.text-4xl.font-black.tracking-tight.text-slate-900 Dues
            %p.max-w-2xl.text-sm.leading-6.text-slate-600 Track recurring payments, keep due dates visible, and mark each item paid without losing context.
        .flex.items-center.gap-3
          = render "lists/add_list"

      .mb-5.flex.flex-col.gap-4.sm:flex-row.sm:items-center.sm:justify-between
        .inline-flex.rounded-full.border.border-emerald-200.bg-white.p-1.shadow-sm{ role: "tablist" }
          = button_to "Calendar", calendar_lists_path, method: :get, form: { class: "inline-block" }, class: "rounded-full px-4 py-2 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50"
          = button_to "List", lists_path, method: :get, form: { class: "inline-block" }, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm"
        .text-sm.font-semibold.text-slate-700
          %span{ data: { total_dues_label: true, paid_dues: @list_dues_paid, total_dues: @list_total_dues } }= "Total dues: #{@list_dues_paid}/#{@list_total_dues}"

      .rounded-3xl.border.border-slate-200.bg-white.shadow-xl
        .flex.flex-col.gap-4.border-b.border-slate-100.p-6.sm:flex-row.sm:items-start.sm:justify-between
          %div.space-y-2
            %h2.text-xl.font-bold.text-slate-900 Current list
            %p.text-sm.leading-6.text-slate-500 Review what is due, mark items done, and adjust the visible range when needed.
          %details.relative
            %summary.list-none.cursor-pointer.rounded-full.border.border-slate-200.bg-white.p-2.text-slate-600.shadow-sm.transition.hover:border-slate-300.hover:text-slate-900.focus:outline-none.focus-visible:ring-2.focus-visible:ring-emerald-400
              = render "svg/gear"
            .absolute.right-0.z-20.mt-3.w-80.rounded-2xl.border.border-slate-200.bg-white.p-4.shadow-xl
              = render "layouts/select_dates"
        .p-6
          = render "lists/check_list"

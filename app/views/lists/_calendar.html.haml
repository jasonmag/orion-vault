- month_start = @calendar_month_start
- month_end = @calendar_month_end
- previous_month = month_start.prev_month.strftime("%Y-%m")
- next_month = month_start.next_month.strftime("%Y-%m")
- grid_start = month_start.beginning_of_week(:sunday)
- grid_end = month_end.end_of_week(:sunday)
- day_names = Date::ABBR_DAYNAMES
- due_map = @calendar_lists_with_due_dates.select { |entry| entry[:due_date].present? }.group_by { |entry| entry[:due_date] }
- today = Date.current

%div.flex.flex-col.gap-5.mb-6
  %div.flex.flex-col.gap-4.sm:flex-row.sm:items-start.sm:justify-between
    %div
      %h2.text-2xl.font-bold.text-slate-900= month_start.strftime("%B %Y")
      %p.text-sm.leading-6.text-slate-500 Select any day to open the dues scheduled for that date.
    .flex.flex-col.gap-3.sm:flex-row.sm:items-center.sm:gap-4
      .inline-flex.items-center.rounded-full.border.border-slate-200.bg-white.text-sm.font-semibold.text-slate-700.shadow-sm
        = link_to calendar_lists_path(month: previous_month), class: "rounded-l-full px-4 py-2 transition hover:bg-slate-50" do
          &larr;
        %span.border-x.border-slate-200.px-4.py-2= month_start.strftime("%b %Y")
        = link_to calendar_lists_path(month: next_month), class: "rounded-r-full px-4 py-2 transition hover:bg-slate-50" do
          &rarr;
      %div{ class: "flex flex-wrap gap-2 text-xs text-slate-500 sm:block" }
        %span.inline-flex.items-center.gap-2
          %span.inline-block.h-2.5.w-2.5.rounded-full.bg-emerald-500
          Due today
        %span.inline-flex.items-center.gap-2.sm:ml-4
          %span.inline-block.h-2.5.w-2.5.rounded-full.bg-emerald-300
          Due this month

%div{ class: "mb-2 grid grid-cols-7 gap-px overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 text-[10px] font-semibold text-slate-500 md:text-[11px]" }
  - day_names.each do |day|
    %div{ class: "border border-slate-200 bg-slate-50 py-2 text-center uppercase tracking-wide" }= day

%div.grid.grid-cols-7.gap-px.overflow-hidden.rounded-3xl.border.border-slate-200.bg-slate-200
  - (grid_start..grid_end).each do |day|
    - in_month = day.month == month_start.month
    - entries = due_map[day] || []
    - is_today = day == today
    - has_dues = entries.any?
    - base_classes = in_month ? "bg-white text-slate-700" : "bg-slate-50 text-slate-400"
    - today_classes = is_today ? "ring-2 ring-emerald-500 ring-inset" : ""
    - due_classes = has_dues ? "bg-emerald-50/70" : ""
    = link_to lists_path(start_date: day, end_date: day), class: "block min-h-[84px] overflow-hidden border border-slate-200 p-2 transition-colors hover:bg-emerald-50 md:aspect-square md:min-h-0 md:p-3.5 lg:p-4 #{base_classes} #{today_classes} #{due_classes}" do
      .flex.items-center.justify-between
        %div{ class: "text-[11px] font-semibold md:text-sm" }= day.day
        - if has_dues
          %span{ class: "inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-emerald-600 px-1.5 text-[10px] font-semibold text-white md:h-5 md:min-w-[22px] md:text-[11px]" }= entries.size
      - if entries.any?
        %ul{ class: "mt-2 hidden space-y-1 md:block" }
          - entries.first(3).each do |entry|
            %li.text-xs.text-slate-700.truncate.lg:text-sm= entry[:list].name
          - if entries.size > 3
            %li{ class: "text-[11px] text-slate-500" }= "+#{entries.size - 3} more"

.bg-background
  .relative.isolate.mx-auto.px-6.pb-16.pt-8.lg:px-8
    .mx-auto.max-w-5xl.py-12.sm:py-16
      .mb-8.flex.flex-col.gap-4.lg:flex-row.lg:items-end.lg:justify-between
        %div.space-y-3
          %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.uppercase.tracking-widest.text-emerald-700 Calendar View
          %div.space-y-2
            %h1.text-4xl.font-black.tracking-tight.text-slate-900 Dues Calendar
            %p.max-w-2xl.text-sm.leading-6.text-slate-600 Scan the month, spot busy due-date clusters, and jump straight into the day you want to review.
        .flex.items-center.gap-3
          = render "lists/add_list"

      .mb-5.flex.flex-col.gap-4.sm:flex-row.sm:items-center.sm:justify-between
        .inline-flex.rounded-full.border.border-emerald-200.bg-white.p-1.shadow-sm{ role: "tablist" }
          = button_to "Calendar", calendar_lists_path, method: :get, form: { class: "inline-block" }, class: "rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm"
          = button_to "List", lists_path, method: :get, form: { class: "inline-block" }, class: "rounded-full px-4 py-2 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50"
        .text-sm.font-semibold.text-slate-700
          %span= "Total dues: #{@calendar_dues_paid}/#{@calendar_total_dues}"

      .rounded-3xl.border.border-slate-200.bg-white.p-6.shadow-xl
        = render "lists/calendar"

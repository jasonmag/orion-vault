%body.bg-background
  .bg-background
    .relative.isolate.mx-auto.px-6.pb-16.pt-8.lg:px-8
      .mx-auto.max-w-6xl.py-12.sm:py-16
        .mb-8.flex.flex-col.gap-4.lg:flex-row.lg:items-end.lg:justify-between
          .space-y-3
            %span.inline-flex.items-center.rounded-full.bg-emerald-100.px-3.py-1.text-xs.font-semibold.uppercase.tracking-widest.text-emerald-700 Overview
            .space-y-2
              %h1.text-4xl.font-black.tracking-tight.text-slate-900 Frequency Overview
              %p.max-w-2xl.text-sm.leading-6.text-slate-600 Review dues grouped by cadence, switch between active and expired items, and scan schedules faster.
          .flex.flex-wrap.items-center.gap-3
            = render "lists/add_list"
            = link_to lists_path, class: "inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" do
              Back to Dues

        - current_active = @status != "expired"
        - current_classes = "rounded-full px-4 py-2 text-sm font-semibold transition " + (current_active ? "bg-slate-900 text-white shadow-sm" : "text-slate-700 hover:bg-slate-50")
        - expired_classes = "rounded-full px-4 py-2 text-sm font-semibold transition " + (!current_active ? "bg-slate-900 text-white shadow-sm" : "text-slate-700 hover:bg-slate-50")
        .mb-8.inline-flex.rounded-full.border.border-slate-200.bg-white.p-1.shadow-sm{ role: "tablist" }
          = link_to "Current/Active", frequency_lists_path(status: "current"), class: current_classes
          = link_to "Expired", frequency_lists_path(status: "expired"), class: expired_classes

        - frequencies = PaymentSchedule::FREQUENCIES + ["unscheduled"]
        - available_frequencies = frequencies.select do |frequency|
          - (@lists_by_frequency[frequency] || []).any?
        - if available_frequencies.any?
          .space-y-6{ data: { controller: "frequency-tabs" } }
            .flex.flex-wrap.gap-2{ role: "tablist" }
              - available_frequencies.each_with_index do |frequency, index|
                - label = frequency == "unscheduled" ? "Unscheduled" : frequency.capitalize.gsub("_", " ")
                - active = index.zero?
                %button.rounded-full.border.border-slate-200.bg-white.px-4.py-2.text-sm.font-semibold.text-slate-700.shadow-sm.transition.hover:bg-slate-50{ type: "button", role: "tab", aria: { selected: active ? "true" : "false", controls: "frequency-panel-#{frequency}" }, data: { action: "click->frequency-tabs#show", frequency_tabs_target: "tab", frequency_value: frequency, active: active ? "true" : nil, active_class: "bg-emerald-600 text-white border-emerald-600", inactive_class: "bg-white text-slate-700 border-slate-200 hover:bg-slate-50" } }= label

            - available_frequencies.each_with_index do |frequency, index|
              - lists = @lists_by_frequency[frequency] || []
              - label = frequency == "unscheduled" ? "Unscheduled" : frequency.capitalize.gsub("_", " ")
              %section{ id: "frequency-panel-#{frequency}", role: "tabpanel", class: (index.zero? ? nil : "hidden"), data: { frequency_tabs_target: "panel", frequency: frequency } }
                .rounded-3xl.border.border-slate-200.bg-white.shadow-xl
                  .flex.flex-col.gap-3.border-b.border-slate-100.p-6.sm:flex-row.sm:items-end.sm:justify-between
                    .space-y-2
                      %h2.text-xl.font-bold.text-slate-900= label
                      %p.text-sm.text-slate-500
                        #{lists.size} item#{lists.size == 1 ? "" : "s"} in this group
                  .overflow-x-auto
                    %table.min-w-full
                      %thead
                        %tr.border-b.border-slate-100.bg-slate-50
                          %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Name
                          %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Frequency
                          %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Effective Dates
                          %th.px-5.py-4.text-right.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Price
                          %th.px-5.py-4.text-left.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Status
                      %tbody.divide-y.divide-slate-100
                        - lists.each do |list|
                          - frequency_label = list.payment_schedule&.human_readable_frequency || "Unscheduled"
                          - start_date = list.effective_start_date&.strftime("%b %d, %Y") || "N/A"
                          - end_date = list.effective_end_date&.strftime("%b %d, %Y") || "No end"
                          - status_label = list.effective_end_date.present? && list.effective_end_date < Date.current ? "Expired" : "Current"
                          - status_classes = status_label == "Expired" ? "bg-red-100 text-red-700" : "bg-emerald-100 text-emerald-700"
                          %tr.transition.hover:bg-slate-50
                            %td.px-5.py-4.text-sm.text-slate-900
                              = link_to list.name, list_path(list), class: "font-semibold text-slate-900 underline decoration-emerald-300 decoration-2 underline-offset-4"
                            %td.px-5.py-4.text-sm.text-slate-700= frequency_label
                            %td.px-5.py-4.text-sm.text-slate-700= "#{start_date} - #{end_date}"
                            %td.px-5.py-4.text-right.text-sm.font-semibold.text-slate-900
                              = Money.new(list.price * 100, current_user.user_setting.default_currency).format(symbol: true, with_currency: false)
                            %td.px-5.py-4.text-sm.text-slate-700
                              %span.inline-flex.items-center.rounded-full.px-3.py-1.text-xs.font-semibold{ class: status_classes }= status_label
        - else
          .rounded-3xl.border.border-dashed.border-slate-300.bg-slate-50.p-10.text-center
            %p.text-base.font-semibold.text-slate-700 No items found for this status.
            %p.mt-2.text-sm.text-slate-500 Switch the filter or add a new list to populate this overview.
